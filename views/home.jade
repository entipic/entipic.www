extends layouts/root

block content
  section.hero
    h1.hero-title
      | A picture for
      br
      span.accent every topic.
    p.hero-lede
      | Entipic gives every entity — people, places, brands — a representative
      | image you can freely use in any application. Think Gravatar, but for topics.
    p.stats
      | Indexing #[span.count= countTopics.toLocaleString()] topics, #[span.count= countUniqueNames.toLocaleString()] names and #[span.count= countPictures.toLocaleString()] pictures.

  section.section
    .section-head
      h2.section-title Examples
      a.section-link(href='/help') How it works →
    .examples
      each item in exampleTopics
        a.example(href=links.topic(item.slug), title=item.name)
          .example-thumb
            img(src=entipicUrl(item.name, 'c', item.lang), alt=item.name, loading='lazy')
          span.example-name= item.name

  section.section
    .section-head
      h2.section-title Latest topics
    ul.latest
      each item in latestTopics
        li.latest-item
          a(href=links.topic(item.slug), title=item.name)
            img(src=entipicUrl.picture(item.pictureId, 'f'), alt=item.name, loading='lazy')
