doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(name='theme-color', content='#fafaf7')
    title= (site.head.title || site.title)
    if (site.head.description)
      meta(name='description', content=site.head.description)
    if (site.head.keywords)
      meta(name='keywords', content=site.head.keywords)
    block styles
    link(type='text/css', rel='stylesheet', href=links.assets.css.main({v: project.version}))
    if (site.head.canonical)
      link(rel='canonical', href=site.head.canonical)
  body
    header.site-header
      .container
        a.brand(href=links.home(), title=project.name) entipic
        nav.site-nav
          a(href='/help', class=(site.currentPage==='help'?'is-active':null)) Help

    main.site-main
      .container
        block content

    footer.site-footer
      .container
        span © entipic
        a(href='https://github.com/entipic', target='_blank', rel='noopener') Source on GitHub

    block scripts

    if (config.googleAnalyticsId)
      script.
        (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
        })(window,document,'script','//www.google-analytics.com/analytics.js','ga');
        ga('create', '#{config.googleAnalyticsId}', 'auto');
        ga('send', 'pageview');
